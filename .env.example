# CyberForge — Environment Variables
# Copy this file to .env and fill in values as needed.
# All variables are OPTIONAL — the app runs without any of them.

# ── Ollama ──
# URL of your local Ollama server (default: http://localhost:11434)
# OLLAMA_HOST=http://localhost:11434

# ── Hugging Face ──
# Required only for downloading gated models (e.g. Llama, Mistral).
# Get a token at https://huggingface.co/settings/tokens
# HF_TOKEN=

# ── OpenRouter (optional) ──
# API key for OpenRouter cloud inference.  Leave blank for local-only mode.
# OPENROUTER_API_KEY=

# ── Directories (defaults are usually fine) ──
# CYBERFORGE_CONFIG_DIR=data
